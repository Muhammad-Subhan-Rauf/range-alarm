{
  "expo": {
    "name": "Range Alarm",
    "slug": "alarmApp",
    "scheme": "rangealarm",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0B14"
    },
    "android": {
      "package": "com.studiolab.rangealarm",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B0B14"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "RECEIVE_BOOT_COMPLETED",
        "POST_NOTIFICATIONS",
        "WAKE_LOCK",
        "VIBRATE",
        "USE_FULL_SCREEN_INTENT",
        "READ_MEDIA_AUDIO"
      ]
    },
    "ios": {
      "supportsTablet": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": false
        }
      ],
      "expo-sqlite",
      "expo-audio",
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B0B14",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
